# Database
DATABASE_URL=postgresql://user:password@host:5432/ghostchat?sslmode=require

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_minimum_64_chars
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens

# HMAC for group anonymization (REQUIRED - no fallback)
HMAC_SECRET=another_long_random_secret_for_hmac

# CORS
ALLOWED_ORIGIN=https://your-frontend-domain.com

# Admin
ADMIN_SECRET=strong_admin_password_here

# Server
PORT=3000
NODE_ENV=production
